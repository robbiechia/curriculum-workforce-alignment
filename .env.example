# Copy this file to .env for local use.
DATABASE_URL=postgresql://postgres:<password>@<host>.supabase.co:5432/postgres

# Optional: OpenAI-compatible LLM settings for the Natural-Language Job Assistant page.
# If unset, the page will still work but will show a deterministic fallback summary
# instead of an LLM-generated explanation.
OPENAI_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4.1-mini
LLM_TIMEOUT_SECONDS=30
